auth_host=http://localhost:5010
user_host=http://localhost:5020
search_host=http://localhost:5030

# Option A — use a pre-existing CARDS legacy session token (skip login step)
# Get one by logging into staging.relpro.com and copying the userToken cookie/header.
# test_token=PASTE_CARDS_SESSION_TOKEN_HERE

# Option B — login via Auth.Service (new-style token, for dev only)
test_email=SET_YOUR_EMAIL_HERE
test_password=SET_YOUR_PASSWORD_HERE

# Endpoint params
search_query=relpro
test_user_id=SET_A_VALID_USER_ID_HERE
