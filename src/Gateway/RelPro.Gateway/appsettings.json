{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Urls": "http://localhost:5000",

  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Order": 0,
        "Match": { "Path": "/v1/auth/{**catch-all}" }
      },
      "user": {
        "ClusterId": "user",
        "Order": 0,
        "Match": { "Path": "/v1/user/{**catch-all}" }
      },
      "search": {
        "ClusterId": "search",
        "Order": 0,
        "Match": { "Path": "/v1/search/{**catch-all}" }
      },
      "legacy": {
        "ClusterId": "legacy",
        "Order": 999,
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5010" }
        }
      },
      "user": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5020" }
        }
      },
      "search": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5030" }
        }
      },
      "legacy": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5200" }
        }
      }
    }
  }
}
