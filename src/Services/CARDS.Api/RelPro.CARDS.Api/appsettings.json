{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Urls": "http://localhost:5010",

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "MySql": {
    "ConnectionString": "Server=localhost;Port=3306;Database=relpro;Uid=app;Pwd=SET_VIA_SECRET;"
  },

  "LegacySession": {
    "SessionTimeoutMinutes": 720,
    "CacheMinutes": 5
  },

  // --- Error tracking --- enable by setting a real Dsn; empty string = disabled
  "Sentry": {
    "Dsn": "",
    "Environment": "development",
    "TracesSampleRate": 0.0
  },

  // --- Product analytics --- enable by setting AccountIdPrefix (e.g. "staging_"); empty = disabled
  "Pendo": {
    "AccountIdPrefix": ""
  },

  // --- Outbound email (quota-exceeded notifications, login-failure alerts) ---
  "Email": {
    "Host": "smtp.mandrillapp.com",
    "Port": 587,
    "User": "SET_VIA_SECRET",
    "Password": "SET_VIA_SECRET",
    "Ssl": "TLS/SSL, RFC3207",
    "FromAddress": "SET_VIA_CONFIG",
    "InternalTo": "SET_VIA_CONFIG",
    "UserQuotaEmailSubject": "Your RelPro License Needs to Be Renewed/Upgraded",
    "UserQuotaEmailTemplate": "ProdUserQuotaEmailTemplate.html",
    "UserQuotaAdminSubject": "{0}'s RelPro License Has Ended",
    "UserQuotaAdminTemplate": "ProdAdminQuotaEmailTemplate.html",
    "LoginFailureLimit": 5,
    "LoginFailureNotify": "SET_VIA_CONFIG"
  },

  // --- Contract / access-control thresholds ---
  "Contracts": {
    "MaxFreeTrial": 1000,
    "FailureLimit": 10,
    "FailureTimeMinutes": 30
  },

  // --- MongoDB (Atlas Search for people/companies + vendor collections) ---
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017/test",

    // People / company search (Prospector)
    "ProspectorDb": "Zoom",

    // BoardEx executive data
    "BoardExDb": "BoardEx",
    "BoardExPeCollection": "SET_VIA_CONFIG",

    // Net-Zero tracker
    "NetZeroDb": "ZeroTracker",
    "NetZeroCollection": "SET_VIA_CONFIG",

    // Science Based Targets (SBTi)
    "SbtDb": "ScienceBasedTargets",
    "SbtCollection": "SET_VIA_CONFIG",

    // CRE concordance (First American)
    "CreDb": "FirstAmerican",
    "CreCollectionName": "SET_VIA_CONFIG",
    "CreIndexName": "SET_VIA_CONFIG",
    "CrePassword": "SET_VIA_SECRET",

    // GenAI / AI features
    "AiDb": "relpro_AI",
    "AiUserInterestListCollection": "AI_UserInterestList",
    "AiFeedbackCollection": "AI_Feedbacks",

    // CreditSafe
    "CreditSafeDb": "CreditSafe",
    "CollateralCollection": "distinct_collateral_values",

    // Concordance search limits
    "ConcordanceDataSourcesLimit": 1000
  },

  // --- Prospector / Atlas Search index ---
  "ProspectorSearch": {
    "AtlasIndexName": "default"
  },

  // --- AWS (S3 for profile attachments, bulk exports) ---
  "Aws": {
    "Region": "us-east-1",
    "S3Bucket": "SET_VIA_CONFIG",
    "S3SourceBucket": "relpro.source",
    "S3KmsKey": "alias/S3KeyEast1",
    "AccessKey": "SET_VIA_SECRET",
    "SecretKey": "SET_VIA_SECRET",
    "S3MinutesExpires": 6000,
    "MaxBulkSearchResults": 100
  },

  // --- List import limits ---
  "Import": {
    "MaxRowsAllowed": 200
  },

  // --- Google Vertex AI / Gemini (AI smart search, recommendations) ---
  "GenAi": {
    "ProjectId": "SET_VIA_SECRET",
    "Location": "us-central1",
    "ModelId": "gemini-2.5-flash",
    "TimeoutMs": 15000,
    "ConfigPath": "SET_VIA_SECRET"
  },

  // --- ZoomInfo (people / company data enrichment) ---
  "Zoom": {
    "ServiceUrl": "https://partnerapi.zoominfo.com/partnerapi/v4/",
    "PartnerCode": "SET_VIA_SECRET",
    "Password": "SET_VIA_SECRET",
    "MaxSearchResults": 50,
    "RecordsPerPage": 25,
    "TimeoutMs": 15000
  },

  // --- BoardEx (executive relationship data) ---
  "Boardex": {
    "MatchThreshold": 100,
    "MinMatchThreshold": 30,
    "MaxSearchResults": 100,
    "TimeoutMs": 10000
  },

  // --- Muraena (email enrichment API) ---
  "Muraena": {
    "ApiKey": "SET_VIA_SECRET",
    "TimeoutMs": 15000
  },

  // --- QUIN (street address → geo-coordinates) ---
  "Quin": {
    "BaseUrl": "http://internal-Test-Data-Science-ALB-946834862.us-east-1.elb.amazonaws.com/street2coordinates",
    "ConfidenceThreshold": 45
  },

  // --- Match / ranking thresholds ---
  "Matching": {
    "CleanScore": 95,
    "LdThreshold": 80,
    "MaxResults": 100,
    "RecordsPerPage": 30,
    "MatchThreshold": 100,
    "MaxMatching": 250
  },

  // --- Service metadata (used in observability tags) ---
  "Service": {
    "Name": "RelPro CARDS API",
    "HttpConnectionLimit": 150
  }
}
